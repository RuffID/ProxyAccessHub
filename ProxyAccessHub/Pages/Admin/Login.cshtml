@page
@model ProxyAccessHub.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Вход администратора";
}

<main class="screen-page">
    <section class="screen-shell" aria-label="Вход администратора">
        <div class="screen-copy">
            <p class="screen-eyebrow">Административный вход</p>
            <h1 class="screen-title">Отдельный вход для управления пользователями и тарифами</h1>
            <p class="screen-description">
                Здесь будет пароль администратора из конфигурации и переход к минимальной панели управления пользователями.
            </p>
        </div>

        <form class="screen-form" method="post">
            <label class="screen-label" asp-for="Password"></label>
            <input class="screen-input" asp-for="Password" autocomplete="current-password" />
            <span class="screen-hint">Страница подготовлена как стартовая точка базовой административной панели.</span>
            <button class="screen-button" type="submit">Войти</button>
        </form>
    </section>
</main>
