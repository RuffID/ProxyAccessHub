@page "/login"
@model ProxyAccessHub.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Вход администратора";
}

<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 text-center mb-4">Вход администратора</h1>

                    <form method="post" class="d-grid gap-3">
                        <div>
                            <label class="form-label" asp-for="Password"></label>
                            <input class="form-control form-control-lg" asp-for="Password" autocomplete="current-password" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger mb-0" role="alert">@Model.ErrorMessage</div>
                        }

                        <button class="btn btn-dark btn-lg" type="submit">Войти</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
