@page
@model ProxyAccessHub.Pages.Admin.TariffsModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Тарифы";
    string? requestVerificationToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<meta name="request-verification-token" content="@requestVerificationToken" />

<main class="container py-4 py-lg-5">
    <div id="adminTariffsPage"></div>
</main>

<script src="~/js/admin-tariffs.js"></script>
