@page
@model ProxyAccessHub.Pages.Admin.UsersModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Пользователи";
    string? requestVerificationToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<meta name="request-verification-token" content="@requestVerificationToken" />

<main class="container py-4 py-lg-5">
    <div id="adminUsersPage"></div>
</main>

<script src="~/js/admin-users.js"></script>
