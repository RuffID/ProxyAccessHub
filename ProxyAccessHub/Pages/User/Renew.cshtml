@page
@model ProxyAccessHub.Pages.User.RenewModel
@using System.Globalization
@{
    ViewData["Title"] = "Продлить прокси";
    ViewData["UsePlainTitle"] = true;
}

@if (Model.LookupResult is not null)
{
    ViewData["UserBadgeText"] = Model.LookupResult.TelemtUserId;
}

<main class="container py-4 py-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <h1 class="display-6 mb-3">Продлить прокси</h1>
                        <p class="text-secondary mb-0">Вставьте ссылку, которая выдавалась при подключении прокси.</p>
                    </div>

                    <form method="get" class="row g-3 align-items-end mb-4">
                        <div class="col-12 col-lg">
                            <label class="form-label fw-semibold" asp-for="SearchValue"></label>
                            <input class="form-control form-control-lg" asp-for="SearchValue" autocomplete="off" />
                        </div>
                        <div class="col-12 col-lg-auto">
                            <button class="btn btn-outline-primary btn-lg rounded-pill px-4 fw-semibold" type="submit">Найти пользователя</button>
                        </div>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger mb-4" role="alert">@Model.ErrorMessage</div>
                    }

                    @if (Model.LookupResult is not null)
                    {
                        <div class="mb-4 text-start">
                            <div class="small fw-semibold text-secondary mb-2">id: @Model.LookupResult.TelemtUserId</div>
                        </div>

                        <div class="row g-3 mb-4 justify-content-center">
                            <div class="col-12 col-md-6">
                                <div class="card h-100 border">
                                    <div class="card-body">
                                        <div class="text-uppercase small fw-semibold text-secondary mb-2">Текущий баланс</div>
                                        <div class="fs-4 fw-semibold">@Model.LookupResult.BalanceRub.ToString("0.00", CultureInfo.InvariantCulture) ₽</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="card h-100 border">
                                    <div class="card-body">
                                        <div class="text-uppercase small fw-semibold text-secondary mb-2">Оплачено до</div>
                                        <div class="fs-4 fw-semibold">@(Model.LookupResult.AccessPaidToUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm", CultureInfo.InvariantCulture) ?? "Не оплачено")</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="card h-100 border">
                                    <div class="card-body">
                                        <div class="text-uppercase small fw-semibold text-secondary mb-2">К оплате</div>
                                        <div class="fs-4 fw-semibold">@Model.LookupResult.AmountRequiredRub.ToString("0.00", CultureInfo.InvariantCulture) ₽</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (Model.LookupResult.IsUnlimited)
                        {
                            <button class="btn btn-secondary btn-lg rounded-pill px-4 fw-semibold" type="button" disabled>Для безлимитного тарифа оплата не требуется</button>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="CreatePayment" class="mb-4">
                                <input type="hidden" name="userId" value="@Model.LookupResult.UserId" />
                                <input type="hidden" name="preservedSearchValue" value="@Model.SearchValue" />
                                <button class="btn btn-outline-primary btn-lg rounded-pill px-4 fw-semibold" type="submit">Перейти к оплате в YooMoney</button>
                            </form>
                        }

                        @if (Model.PaymentForm is not null)
                        {
                            <div class="card border">
                                <div class="card-body p-4">
                                    <div class="text-center mb-4">
                                        <div class="text-uppercase small fw-semibold text-secondary mb-2">Заявка создана</div>
                                        <h2 class="h3 mb-2">Оплата продления через ЮMoney</h2>
                                        <p class="text-secondary mb-0">
                                            Метка платежа: @Model.PaymentForm.Label. Заявка действует до
                                            @Model.PaymentForm.ExpiresAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm", CultureInfo.InvariantCulture).
                                        </p>
                                    </div>

                                    <form method="post" action="@Model.PaymentForm.FormActionUrl" class="d-grid gap-4">
                                        <input type="hidden" name="receiver" value="@Model.PaymentForm.Receiver" />
                                        <input type="hidden" name="quickpay-form" value="button" />
                                        <input type="hidden" name="label" value="@Model.PaymentForm.Label" />
                                        <input type="hidden" name="sum" value="@Model.PaymentForm.SumRub.ToString("0.00", CultureInfo.InvariantCulture)" />
                                        <input type="hidden" name="successURL" value="@Model.PaymentForm.SuccessUrl" />

                                        <div class="row g-3">
                                            <div class="col-12 col-md-6">
                                                <div class="card h-100 border">
                                                    <div class="card-body">
                                                        <div class="text-uppercase small fw-semibold text-secondary mb-2">Сумма к оплате</div>
                                                        <div class="fs-4 fw-semibold">@Model.PaymentForm.SumRub.ToString("0.00", CultureInfo.InvariantCulture) ₽</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-12 col-md-6">
                                                <div class="card h-100 border">
                                                    <div class="card-body">
                                                        <div class="text-uppercase small fw-semibold text-secondary mb-3">Способ оплаты</div>
                                                        <div class="form-check mb-2">
                                                            <input class="form-check-input" type="radio" name="paymentType" id="paymentTypePc" value="PC" checked />
                                                            <label class="form-check-label" for="paymentTypePc">ЮMoney</label>
                                                        </div>
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio" name="paymentType" id="paymentTypeAc" value="AC" />
                                                            <label class="form-check-label" for="paymentTypeAc">Банковская карта</label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div>
                                            <button class="btn btn-outline-primary btn-lg rounded-pill px-4 fw-semibold" type="submit">Перейти на страницу оплаты ЮMoney</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</main>
