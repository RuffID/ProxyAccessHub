@page
@model ProxyAccessHub.Pages.User.RenewModel
@{
    ViewData["Title"] = "Продление подписки";
}

@if (Model.LookupResult is not null)
{
    ViewData["UserBadgeText"] = Model.LookupResult.TelemtUserId;
}

<main class="screen-page">
    <section class="screen-shell" aria-label="Экран продления подписки">
        <div class="screen-copy">
            <p class="screen-eyebrow">Продление подписки</p>
            <h1 class="screen-title">Поиск существующего пользователя для продления доступа</h1>
            <p class="screen-description">
                Введите `telemt user id` или точное окончание proxy-ссылки.
            </p>
        </div>

        <form class="screen-form" method="post">
            <label class="screen-label" asp-for="SearchValue"></label>
            <input class="screen-input" asp-for="SearchValue" autocomplete="off" />
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <span class="screen-hint">@Model.ErrorMessage</span>
            }
            else
            {
                <span class="screen-hint">Поддерживается telemt id, полный `tg://proxy...` или точное окончание ссылки.</span>
            }
            <button class="screen-button" type="submit">Найти пользователя</button>
        </form>

        @if (Model.LookupResult is not null)
        {
            <section class="renew-result" aria-label="Результат поиска пользователя">
                <div class="renew-result-header">
                    <p class="screen-eyebrow">Пользователь найден</p>
                    <h2 class="renew-result-title">@Model.LookupResult.TelemtUserId</h2>
                    <p class="renew-result-subtitle">Совпадение: @Model.LookupResult.SearchKind</p>
                </div>

                <div class="renew-result-grid">
                    <article class="renew-result-card">
                        <span class="renew-result-label">Текущий тариф</span>
                        <strong class="renew-result-value">@Model.LookupResult.TariffName</strong>
                        <span class="renew-result-note">Код тарифа: @Model.LookupResult.TariffCode</span>
                    </article>

                    <article class="renew-result-card">
                        <span class="renew-result-label">Текущий баланс</span>
                        <strong class="renew-result-value">@Model.LookupResult.BalanceRub.ToString("0.00") ₽</strong>
                        <span class="renew-result-note">Остаток денег не сгорает и остаётся на балансе.</span>
                    </article>

                    <article class="renew-result-card">
                        <span class="renew-result-label">Оплачено до</span>
                        <strong class="renew-result-value">
                            @(Model.LookupResult.AccessPaidToUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Не оплачено")
                        </strong>
                        <span class="renew-result-note">Текущий оплаченный срок подписки пользователя.</span>
                    </article>

                    <article class="renew-result-card">
                        <span class="renew-result-label">Сумма следующего периода</span>
                        <strong class="renew-result-value">@Model.LookupResult.AmountRequiredRub.ToString("0.00") ₽</strong>
                        <span class="renew-result-note">
                            @if (Model.LookupResult.IsUnlimited)
                            {
                                @:Безлимитный тариф не требует ежемесячного продления.
                            }
                            else
                            {
                                @:Следующий полный период: @Model.LookupResult.PeriodMonths мес.
                            }
                        </span>
                    </article>
                </div>

                <article class="renew-result-card renew-result-card-wide">
                    <span class="renew-result-label">Proxy-ссылка</span>
                    <strong class="renew-result-value renew-result-link">@Model.LookupResult.ProxyLink</strong>
                    <span class="renew-result-note">Для оплаты создаётся отдельная локальная заявка с уникальной меткой YooMoney.</span>
                </article>

                @if (Model.LookupResult.IsUnlimited)
                {
                    <button class="screen-button screen-button-disabled" type="button" disabled>Для безлимитного тарифа оплата не требуется</button>
                }
                else
                {
                    <form method="post" asp-page-handler="CreatePayment">
                        <input type="hidden" name="userId" value="@Model.LookupResult.UserId" />
                        <button class="screen-button" type="submit">Перейти к оплате</button>
                    </form>
                }

                @if (Model.PaymentForm is not null)
                {
                    <section class="payment-form-shell" aria-label="Форма оплаты ЮMoney">
                        <div class="renew-result-header">
                            <p class="screen-eyebrow">Заявка создана</p>
                            <h2 class="renew-result-title">Оплата продления через ЮMoney</h2>
                            <p class="renew-result-subtitle">
                                Метка платежа: @Model.PaymentForm.Label. Заявка действует до
                                @Model.PaymentForm.ExpiresAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm").
                            </p>
                        </div>

                        <form class="payment-form" method="post" action="@Model.PaymentForm.FormActionUrl">
                            <input type="hidden" name="receiver" value="@Model.PaymentForm.Receiver" />
                            <input type="hidden" name="quickpay-form" value="button" />
                            <input type="hidden" name="label" value="@Model.PaymentForm.Label" />
                            <input type="hidden" name="sum" value="@Model.PaymentForm.SumRub.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                            <input type="hidden" name="successURL" value="@Model.PaymentForm.SuccessUrl" />

                            <div class="payment-form-grid">
                                <article class="renew-result-card">
                                    <span class="renew-result-label">Сумма к оплате</span>
                                    <strong class="renew-result-value">@Model.PaymentForm.SumRub.ToString("0.00") ₽</strong>
                                    <span class="renew-result-note">Сумма сформирована на стороне сайта по тарифу пользователя.</span>
                                </article>

                                <article class="renew-result-card">
                                    <span class="renew-result-label">Способ оплаты</span>
                                    <label class="payment-method-option">
                                        <input type="radio" name="paymentType" value="PC" checked />
                                        <span>ЮMoney</span>
                                    </label>
                                    <label class="payment-method-option">
                                        <input type="radio" name="paymentType" value="AC" />
                                        <span>Банковская карта</span>
                                    </label>
                                </article>
                            </div>

                            <button class="screen-button" type="submit">Перейти на страницу оплаты ЮMoney</button>
                        </form>
                    </section>
                }
            </section>
        }
    </section>
</main>
