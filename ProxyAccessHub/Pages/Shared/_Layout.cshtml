@using ProxyAccessHub.Core.Authentication
@{
    string? userBadgeText = ViewData["UserBadgeText"] as string;
    if (string.IsNullOrWhiteSpace(userBadgeText)
        && User.HasClaim(UserAccessAuthenticationDefaults.ACCESS_CLAIM_TYPE, UserAccessAuthenticationDefaults.ACCESS_CLAIM_VALUE))
    {
        userBadgeText = "Вход выполнен";
    }
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProxyAccessHub</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <div class="app-header-shell">
            <a class="app-brand" asp-page="/Index">ProxyAccessHub</a>
            <nav class="app-nav" aria-label="Основная навигация">
                <a class="app-nav-link" asp-page="/User/Login">Пользователь</a>
                <a class="app-nav-link" asp-page="/User/Renew">Продление</a>
                <a class="app-nav-link" asp-page="/Admin/Login">Админ</a>
                <a class="app-nav-link" asp-page="/Admin/Users">Пользователи</a>
                <a class="app-nav-link" asp-page="/User/NewConnection">Новое подключение</a>
            </nav>
            @if (!string.IsNullOrWhiteSpace(userBadgeText))
            {
                <button class="app-user-badge" type="button">@userBadgeText</button>
            }
        </div>
    </header>

    @RenderBody()
</body>
</html>
